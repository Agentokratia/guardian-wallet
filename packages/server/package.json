{
	"name": "@agentokratia/guardian-server",
	"version": "0.1.0",
	"description": "Guardian threshold wallet policy server (NestJS)",
	"license": "AGPL-3.0-only",
	"author": "Agentokratia <hello@agentokratia.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/agentokratia/guardian-wallet.git",
		"directory": "packages/server"
	},
	"homepage": "https://github.com/agentokratia/guardian-wallet",
	"bugs": "https://github.com/agentokratia/guardian-wallet/issues",
	"keywords": ["threshold", "wallet", "mpc", "server", "nestjs", "policy", "ethereum", "agent"],
	"type": "module",
	"main": "./dist/main.js",
	"types": "./dist/main.d.ts",
	"files": ["dist"],
	"engines": {
		"node": ">=20.0.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/auth/templates',{recursive:true});cpSync('src/auth/templates/otp-email.html','dist/auth/templates/otp-email.html')\"",
		"dev": "tsx watch --env-file=../../.env src/main.ts",
		"start": "node dist/main.js",
		"lint": "biome check src/",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@agentokratia/guardian-auth": "workspace:*",
		"@agentokratia/guardian-chains": "workspace:*",
		"@agentokratia/guardian-core": "workspace:*",
		"@agentokratia/guardian-schemes": "workspace:*",
		"@nestjs/common": "^11.1.19",
		"@nestjs/core": "^11.1.19",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/platform-express": "^11.1.19",
		"@noble/curves": "^2.2.0",
		"@supabase/supabase-js": "^2.105.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"cookie-parser": "^1.4.6",
		"helmet": "^8.1.0",
		"node-vault": "^0.12.0",
		"reflect-metadata": "^0.2.0",
		"resend": "^6.12.2",
		"rxjs": "^7.8.0",
		"viem": "^2.48.4"
	},
	"devDependencies": {
		"@nestjs/testing": "^11.1.19",
		"@simplewebauthn/types": "^12.0.0",
		"@types/cookie-parser": "^1.4.7",
		"@types/express": "^4.17.0",
		"@types/node": "^20.0.0",
		"tsx": "^4.19.0"
	}
}
