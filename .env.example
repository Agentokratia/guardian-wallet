# =============================================================================
# Guardian Wallet — Local Development Environment
# =============================================================================
#
# ZERO-CONFIG DEV SETUP:
#   cp .env.example .env
#   npx supabase start
#   pnpm --filter @agentokratia/guardian-server dev
#   pnpm --filter @agentokratia/guardian-app dev
#
# Both the server and the dashboard read from THIS file (root .env).
# The server loads it via tsx; Vite reads VITE_* vars via envDir.
# For production, see .env.production.example.
#
# =============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  SERVER                                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

NODE_ENV=development
PORT=8080

# ── Supabase (PostgreSQL) ────────────────────────────────────────────────────
# The service key below is the standard local-dev demo key printed by
# `npx supabase start`. It is NOT a secret — it only works against the
# local Supabase container and is published in Supabase's own docs.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── KMS (share encryption backend) ──────────────────────────────────────────
# local-file: AES-256-GCM with a master key file. Auto-generated on first run.
# vault-kv:   HashiCorp Vault KV v2 (see .env.production.example).
KMS_PROVIDER=local-file
KMS_LOCAL_KEY_FILE=~/.gw/master.key

# ── Authentication ──────────────────────────────────────────────────────────
# Dev-only JWT secret. MUST be replaced in production (min 32 chars).
JWT_SECRET=guardian-dev-jwt-secret-2026-min32ch
JWT_EXPIRY=15m

# ── WebAuthn (Passkey Authentication) ───────────────────────────────────────
# RP_ID must match the domain the dashboard runs on (no port, no protocol).
RP_ID=localhost
RP_NAME=Guardian Wallet

# ── Email (OTP delivery) ───────────────────────────────────────────────────
# console: prints OTP to server logs (dev only).
# resend:  sends real emails via Resend (see .env.production.example).
EMAIL_PROVIDER=console

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── AuxInfo Pool (DKG acceleration) ─────────────────────────────────────────
# Pre-generates Paillier keypairs + ZK proofs so DKG completes in ~1s
# instead of ~120s. Requires the native binary (cargo build --release).
AUXINFO_POOL_TARGET=5
AUXINFO_POOL_LOW_WATERMARK=2
AUXINFO_POOL_MAX_GENERATORS=2

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  DASHBOARD (Vite reads only VITE_* vars from this file)                     │
# └─────────────────────────────────────────────────────────────────────────────┘

# In dev, leave VITE_API_URL unset — Vite's proxy forwards /api to :8080.
# VITE_API_URL=http://localhost:8080
